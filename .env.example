# Non-secret runtime defaults
NODE_ENV=production
API_PROVIDER=openai
API_BASE_URL=https://api.openai.com/v1
API_MODEL=

# Non-secret Telegram metadata
TELEGRAM_BOT_ID=
TELEGRAM_BOT_USERNAME=

# Secret values. Set these in .env on the server and never commit real values.
# Get BOT_TOKEN from @BotFather.
BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
API_KEY=
