# Runtime
NODE_ENV=production

# Telegram bot credentials
# Get this token from @BotFather.
BOT_TOKEN=

# Optional Telegram metadata. These are useful when documenting a new bot
# deployment, but the minimal bot only requires BOT_TOKEN to start.
TELEGRAM_BOT_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_USER_IDS=

# Optional external API credentials for future bot integrations.
# Leave blank if the bot does not call an AI/API provider yet.
API_KEY=
API_BASE_URL=
API_MODEL=
